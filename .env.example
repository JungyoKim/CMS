# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# 파일 업로드 최대 크기 (bytes). 예: 104857600 = 100MB, Infinity = 무제한
BODY_SIZE_LIMIT=104857600

# Database Configuration 
# 로컬 개발 시에는 example.db(생성한 예시 DB) 또는 local.db를 사용합니다.
DATABASE_URL=example.db

# Authentication
# JWT 토큰 암호화를 위한 시크릿 키 (운영 환경에서는 반드시 길고 유추 불가능한 문자열로 변경하세요)
JWT_SECRET=a-very-long-and-secure-random-string-for-jwt-example

# Production Domain
# 운영 환경 배포 시 사용할 도메인 이름 (예: cms.yourcompany.com)
PRODUCTION_DOMAIN=cms.example.com
